{
  "name": "gadgetboy-pos",
  "version": "0.5.19",
  "description": "Minimal desktop POS for tech repair shop (Electron + Vite + React + TS)",
  "main": "app/electron-main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mattstechwisdom/GB-POS.git"
  },
  "author": "",
  "license": "MIT",
  "scripts": {
    "predev": "npm run generate:icon",
    "dev": "npm run dev:split",
    "vite": "vite --config vite.config.ts",
    "typecheck:renderer": "tsc -p tsconfig.json --noEmit",
    "typecheck:main": "tsc -p tsconfig.electron.json --noEmit",
    "typecheck": "npm run typecheck:renderer && npm run typecheck:main",
    "generate:icon": "node tools/generate-icon.cjs",
    "electron:buildmain": "tsc --project tsconfig.electron.json",
    "electron": "wait-on tcp:5173 dist-main/app/electron/electron-main.js && electron ./dist-main/app/electron/electron-main.js",
    "dev:split": "cross-env ELECTRON_DISABLE_SECURITY_WARNINGS=true concurrently -n VITE,ELECTRON -c green,magenta \"npm run vite\" \"npm run electron:buildmain && npm run electron\"",
    "dev:nodemon": "wait-on tcp:5173 dist-main/app/electron/electron-main.js && nodemon --watch dist-main/app/electron --ext js --exec \"electron ./dist-main/app/electron/electron-main.js\"",
    "build": "vite build --config vite.config.ts",
    "build:mobile": "vite build --config vite.mobile.config.ts",
    "build:railway": "npm run build && npm run build:mobile && node tools/merge-web-builds.cjs",
    "android:sync": "npm run build:mobile && cap sync android",
    "android:add": "cap add android",
    "android:open": "cap open android",
    "android:apk": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "start:web": "node tools/start-web.cjs",
    "predist": "npm run generate:icon && npm run typecheck && npm run electron:buildmain && npm run build",
    "dist": "electron-builder --win nsis",
    "postdist": "node -e \"const fs=require('fs'),p=require('path'),pkg=require('./package.json'),v=pkg.version,src=p.join('release','GadgetBoy-POS-Setup-'+v+'.exe'),dst=p.join('release','GadgetBoy-POS-Update-'+v+'.exe');if(fs.existsSync(src)){fs.copyFileSync(src,dst);console.log('Created '+dst);}else{console.warn('Setup exe not found:',src);}\"",
    "changelog": "node tools/generate-patch-notes.js",
    "verify:update-feed": "node tools/verify-update-feed.cjs",
    "test:client-update-api": "node tools/test-client-update-api.cjs",
    "test:gidget-api": "node tools/test-gidget-api.cjs",
    "test:gidget-desktop": "electron tools/test-gidget-desktop-runtime.cjs",
    "test:quote-autofill": "node tools/test-quote-autofill.cjs",
    "import:backup:supabase": "node tools/import-backup-to-supabase.cjs"
  },
  "dependencies": {
    "@capacitor-community/text-to-speech": "^8.0.2",
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@capgo/capacitor-speech-recognition": "^8.1.10",
    "@supabase/supabase-js": "^2.110.1",
    "asar": "^3.2.0",
    "electron-updater": "^6.6.2",
    "html2pdf.js": "^0.12.1",
    "llama-cpp-pro": "^0.2.3",
    "node-llama-cpp": "^3.5.0",
    "nodemailer": "^7.0.12",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-select": "^5.10.2",
    "serve": "^14.2.6",
    "serve-handler": "^6.1.7",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/node": "^24.4.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.180.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "nodemon": "^3.1.10",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.9.2",
    "vite": "^5.0.0",
    "wait-on": "^7.0.1"
  }
}
